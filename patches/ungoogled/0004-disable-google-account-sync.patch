From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: bobium <dev@bobium.org>
Date: Mon, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH] privacy: disable google account sync and sign-in prompts

Completely disables the Chromium sync infrastructure and removes
the UI prompts attempting to force users to sign in to a Google account.

---
 components/sync/base/command_line_switches.cc | 2 +-
 chrome/browser/ui/webui/settings/people_handler.cc | 6 ++++++
 2 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/components/sync/base/command_line_switches.cc b/components/sync/base/command_line_switches.cc
--- a/components/sync/base/command_line_switches.cc
+++ b/components/sync/base/command_line_switches.cc
@@ -14,7 +14,7 @@

 // Disables syncing browser data to a Google Account.
 const char kDisableSync[] = "disable-sync";
-
+// bobium: Sync is disabled permanently at build time.

 // Allows overriding the deferred init fallback timeout.
 const char kSyncDeferredStartupTimeoutSeconds[] =
diff --git a/chrome/browser/ui/webui/settings/people_handler.cc b/chrome/browser/ui/webui/settings/people_handler.cc
--- a/chrome/browser/ui/webui/settings/people_handler.cc
+++ b/chrome/browser/ui/webui/settings/people_handler.cc
@@ -200,6 +200,12 @@
 }

 void PeopleHandler::HandleStartSyncing(const base::Value::List& args) {
+  // bobium: Block sync initiation.
+  // Prevent any attempt to open the sign-in or sync consent dialogs.
+  VLOG(1) << "bobium: Google account sync initiation blocked.";
+  return;
+
   AllowJavascript();
   CHECK_EQ(1U, args.size());
   const base::Value& callback_id = args[0];
--
2.40.1
