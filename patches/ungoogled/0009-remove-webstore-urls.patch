From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: bobium <dev@bobium.org>
Date: Mon, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH] privacy: remove hardcoded Chrome Web Store URLs

Replaces the hardcoded Google Chrome Web Store URLs with local
or unroutable addresses to prevent automatic background extension
updates or tracking from Google servers.

---
 extensions/common/extension_urls.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/extensions/common/extension_urls.cc b/extensions/common/extension_urls.cc
--- a/extensions/common/extension_urls.cc
+++ b/extensions/common/extension_urls.cc
@@ -20,9 +20,8 @@ namespace extension_urls {

 // bobium: Removed Web Store URLs
-const char kChromeWebstoreBaseURL[] = "https://chrome.google.com/webstore";
+const char kChromeWebstoreBaseURL[] = "http://127.0.0.1";

-const char kChromeWebstoreUpdateURL[] =
-    "https://clients2.google.com/service/update2/crx";
+const char kChromeWebstoreUpdateURL[] = "http://127.0.0.1";

 }  // namespace extension_urls
 }  // namespace extensions
--
2.40.1
