From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: bobium <dev@bobium.org>
Date: Mon, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH] privacy: disable safe browsing phone-home routines

Stops Safe Browsing from phoning home to Google servers by
neutering the SafeBrowsingService initialization and API calls.
Instead, it relies on local blocklists or Brave-style native blocking.

---
 chrome/browser/safe_browsing/safe_browsing_service.cc | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/chrome/browser/safe_browsing/safe_browsing_service.cc b/chrome/browser/safe_browsing/safe_browsing_service.cc
--- a/chrome/browser/safe_browsing/safe_browsing_service.cc
+++ b/chrome/browser/safe_browsing/safe_browsing_service.cc
@@ -205,7 +205,11 @@
 }

 void SafeBrowsingService::Initialize() {
-  // Initialize standard Safe Browsing components.
+  // bobium: Do not initialize Google Safe Browsing backend.
+  // Prevent any phone-home connections.
+  VLOG(1) << "bobium: Safe Browsing initialization skipped for privacy.";
+  return;
+
   // Original initialization code...
 }

--
