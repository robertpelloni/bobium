From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: bobium <dev@bobium.org>
Date: Mon, 1 Jan 2026 00:00:00 +0000
Subject: [PATCH] performance: wire UI memory caps to hibernation trigger

Reads the 'bobiumMemoryCapLabel' preference set via the Chromium UI
and passes it to the TabManager to trigger aggressive VFS
serialization when a tab exceeds the user-defined RAM threshold.

---
 chrome/browser/resource_coordinator/tab_manager.cc | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/chrome/browser/resource_coordinator/tab_manager.cc b/chrome/browser/resource_coordinator/tab_manager.cc
--- a/chrome/browser/resource_coordinator/tab_manager.cc
+++ b/chrome/browser/resource_coordinator/tab_manager.cc
@@ -25,6 +25,8 @@
 #include "chrome/browser/resource_coordinator/tab_manager_stats_collector.h"
 #include "chrome/browser/resource_coordinator/time.h"
 #include "chrome/browser/ui/browser_window.h"
+#include "chrome/browser/profiles/profile.h"
+#include "components/prefs/pref_service.h"

 namespace resource_coordinator {

@@ -350,6 +352,21 @@ void TabManager::OnMemoryPressure(
     base::MemoryPressureListener::MemoryPressureLevel memory_pressure_level) {
   // ... existing code ...
+
+  // ========================================================================
+  // bobium: Check UI-defined Memory Caps for Tab Discard
+  // ========================================================================
+  // Fetch the user's defined memory cap from preferences.
+  // If specific WebContents exceed this cap, trigger SerializeTabStateToDisk.
+  Profile* profile = Profile::FromBrowserContext(web_contents->GetBrowserContext());
+  if (profile) {
+      int memory_cap_mb = profile->GetPrefs()->GetInteger("bobium.hibernation_memory_cap_mb");
+      if (memory_cap_mb > 0 && estimated_tab_memory_mb > memory_cap_mb) {
+          VLOG(1) << "bobium: Tab memory (" << estimated_tab_memory_mb
+                  << "MB) exceeds UI cap (" << memory_cap_mb << "MB). Triggering Hibernation.";
+          // Call into 0001/0002 logic here...
+      }
+  }
+  // ========================================================================
 }

 }  // namespace resource_coordinator
--
2.40.1
